---
import Base from '../../layouts/Base.astro';
const azure = "https://static.wixstatic.com/media/5609ea_65bb8f67ff414550b698bf2dcfbd0324~mv2.png/v1/fill/w_360,h_574,al_c,q_90,enc_auto/Promo1%20Book%20Cover.png";
---
<Base title="Books | Chris Stirling" description="The Crimson Cross series — Caribbean adventure set in the Golden Age of Piracy.">
  <style is:global>
    .bookrow{display:grid;grid-template-columns:300px 1fr;gap:44px;align-items:center;background:var(--surface);border:1px solid var(--line);border-radius:16px;padding:34px;box-shadow:0 18px 44px rgba(0,0,0,.35);margin-bottom:34px}
    .bookrow.flip{grid-template-columns:1fr 300px}
    .bookrow.flip .cover{order:2}
    .bookrow .cover img{width:300px;max-width:100%;border-radius:8px;box-shadow:0 16px 36px rgba(0,0,0,.5);display:block}
    .bookrow .tag{display:inline-block;background:var(--brass);color:#2A2010;font-size:11px;font-weight:600;letter-spacing:.08em;text-transform:uppercase;padding:5px 10px;border-radius:5px;margin-bottom:12px}
    .bookrow .price{color:var(--brass);font-weight:600;margin:12px 0}
    .bookrow .cta{display:flex;gap:12px;flex-wrap:wrap;margin-top:16px}
    @media(max-width:820px){.bookrow,.bookrow.flip{grid-template-columns:1fr;text-align:left}.bookrow.flip .cover{order:0}}
  </style>

  <main class="wrap">
    <div class="pagehead">
      <div class="eyebrow">The books</div>
      <h1>The Crimson Cross series</h1>
      <p class="prose" style="margin-top:8px;">A Caribbean saga of vengeance, brotherhood, and buried secrets, set in the Golden Age of Piracy.</p>
    </div>

    <section class="pad">
      <div class="bookrow">
        <div class="cover"><img src={azure} alt="Crimson Cross: Azure Waves cover" /></div>
        <div>
          <span class="tag">Book One · Coming mid-2026</span>
          <h2>Crimson Cross: Azure Waves</h2>
          <p class="prose">When Charleston burns and his family falls, sixteen-year-old Samuel Drayton is cast into the lawless waters of the Caribbean — and must learn the brutal arts of piracy to survive and expose the conspiracy that destroyed his world.</p>
          <div class="price">Hardcover $49.99 · Paperback $19.99</div>
          <div class="cta">
            <a class="btn btn-crimson" href="/books/azure-waves">Learn more</a>
            <a class="btn btn-ghost" href="/#books">Get Chapter One free</a>
          </div>
        </div>
      </div>

      <div class="bookrow flip">
        <div class="cover"><img src={azure} alt="Crimson Cross: The Bermuda Years" style="filter:grayscale(.15) sepia(.15);" /></div>
        <div>
          <span class="tag">Prequel novella</span>
          <h2>Crimson Cross: The Bermuda Years</h2>
          <p class="prose">Before the Azure Waves, there was Bermuda. Step into the sun-bleached coral fortress where Thomas Drayton earned his reputation as a brilliant tactician and devoted family man — the calm before the storm that changes everything.</p>
          <div class="price">$14.99</div>
          <div class="cta">
            <a class="btn btn-crimson" href="/books/bermuda-years">Learn more</a>
          </div>
        </div>
      </div>
    </section>
  </main>
</Base>
