---
import Base from '../layouts/Base.astro';
import { getPosts, coverUrl } from '../lib/wix.mjs';
const posts = await getPosts();
const gradients = [
  'linear-gradient(135deg,#16808E,#14304A)',
  'linear-gradient(135deg,#C5412E,#7A2A1D)',
  'linear-gradient(135deg,#14304A,#16808E)',
  'linear-gradient(135deg,#9C7B2E,#5A4718)'
];
const fmt = (d) => d ? new Date(d).toLocaleDateString('en-CA', { year: 'numeric', month: 'long', day: 'numeric' }) : '';
const blogLd = {
  "@context": "https://schema.org", "@type": "Blog",
  "name": "Chris Stirling — Pirate history & the writing journey",
  "url": "https://www.chrisstirling.com/blog",
  "blogPost": posts.slice(0, 20).map(p => ({
    "@type": "BlogPosting", "headline": p.title,
    "datePublished": p.firstPublishedDate,
    "url": "https://www.chrisstirling.com/blog/" + p.slug
  }))
};
---
<Base title="Blog | Chris Stirling" description="Pirate history and the writing journey behind the Crimson Cross series.">
  <style>
    .feature-list{display:flex;flex-direction:column;gap:46px;margin-top:10px}
    .feature{width:88%;display:grid;grid-template-columns:380px 1fr;background:var(--surface);border:1px solid var(--line);border-radius:16px;overflow:hidden;box-shadow:0 14px 36px rgba(20,40,55,.10);transition:transform .15s ease,border-color .15s ease;color:inherit}
    .feature:hover{transform:translateY(-3px);border-color:var(--teal)}
    .feature.right{margin-left:auto}
    .feature.flip{grid-template-columns:1fr 380px}
    .feature .img{min-height:260px;position:relative;background-size:cover;background-position:center}
    .feature .img img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;display:block}
    .feature.flip .img{order:2}
    .feature .body{padding:30px 34px;display:flex;flex-direction:column;justify-content:center}
    .feature .date{color:var(--brass);font-size:12px;letter-spacing:.1em;text-transform:uppercase;margin-bottom:10px}
    .feature .body h3{font-size:25px;line-height:1.2;margin-bottom:12px;font-family:var(--serif);font-weight:600}
    .feature .body p{color:#3A4A53;font-size:16px;margin-bottom:16px}
    .feature .more{color:var(--crimson);font-weight:600;font-size:14px}
    @media(max-width:820px){.feature,.feature.flip{width:100%;grid-template-columns:1fr}.feature.flip .img{order:0}.feature .img{min-height:200px}}
  </style>

  <main class="wrap">
    <div class="pagehead">
      <div class="eyebrow">The blog</div>
      <h1>Pirate history &amp; the writing journey</h1>
      <p class="prose" style="margin-top:8px;">True stories from the Golden Age of Piracy, and notes from behind the writing desk.</p>
    </div>
    <section class="pad">
      {posts.length === 0 && <p class="prose">No posts yet — check back soon.</p>}
      <div class="feature-list">
        {posts.map((p, i) => {
          const cov = coverUrl(p);
          const flip = i % 2 === 1;
          const grad = gradients[i % gradients.length];
          return (
            <a class={"feature " + (flip ? "right flip" : "left")} href={"/blog/" + p.slug}>
              <div class="img" style={`background:${grad}`}>{cov && <img src={cov} alt="" loading="lazy" />}</div>
              <div class="body">
                <div class="date">{fmt(p.firstPublishedDate)}</div>
                <h3>{p.title}</h3>
                <p>{p.excerpt || ''}</p>
                <span class="more">Read the story →</span>
              </div>
            </a>
          );
        })}
      </div>
    </section>
  </main>
  <script type="application/ld+json" set:html={JSON.stringify(blogLd)} />
</Base>
