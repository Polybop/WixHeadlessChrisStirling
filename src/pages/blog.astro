---
import Base from '../layouts/Base.astro';
---
<Base title="Blog | Chris Stirling" description="Pirate history and the writing journey behind the Crimson Cross series.">
  <style is:global>
    .feature-list{display:flex;flex-direction:column;gap:46px;margin-top:10px}
    .feature{width:72%;display:grid;grid-template-columns:300px 1fr;background:var(--surface);border:1px solid var(--line);border-radius:16px;overflow:hidden;box-shadow:0 18px 44px rgba(0,0,0,.35);transition:transform .15s ease,border-color .15s ease}
    .feature:hover{transform:translateY(-3px);border-color:var(--brass)}
    .feature.right{margin-left:auto}
    .feature.flip{grid-template-columns:1fr 300px}
    .feature .img{min-height:240px;background-size:cover;background-position:center}
    .feature.flip .img{order:2}
    .feature .body{padding:26px 30px;display:flex;flex-direction:column;justify-content:center}
    .feature .date{color:var(--brass);font-size:12px;letter-spacing:.1em;text-transform:uppercase;margin-bottom:10px}
    .feature .body h3{font-size:23px;line-height:1.2;margin-bottom:10px}
    .feature .body p{color:#CFCCC4;font-size:15px;margin-bottom:14px}
    .feature .more{color:var(--crimson);font-weight:600;font-size:14px}
    @media(max-width:820px){.feature,.feature.flip{width:100%;grid-template-columns:1fr}.feature.flip .img{order:0}.feature .img{min-height:200px}}
  </style>

  <main class="wrap">
    <div class="pagehead">
      <div class="eyebrow">The blog</div>
      <h1>Pirate history &amp; the writing journey</h1>
      <p class="prose" style="margin-top:8px;">True stories from the Golden Age of Piracy, and notes from behind the writing desk.</p>
    </div>
    <section class="pad">
      <div class="feature-list" id="posts">
        <p class="prose">Loading the latest…</p>
      </div>
    </section>
  </main>

  <script>
    import { createClient, OAuthStrategy } from '@wix/sdk';
    import { posts } from '@wix/blog';
    const clientId = import.meta.env.PUBLIC_WIX_CLIENT_ID;

    const gradients = [
      'linear-gradient(135deg,#243B4A,#0E1B24)',
      'linear-gradient(135deg,#5A2B22,#1A1F24)',
      'linear-gradient(135deg,#3A4750,#16252F)',
      'linear-gradient(135deg,#6E5326,#1A1F24)'
    ];

    function coverUrl(p){
      const m = p.media || {};
      const img = (m.wixMedia && m.wixMedia.image) || m.image || p.coverImage;
      if (img && img.url) return img.url;
      const id = img && (img.id || img._id);
      if (id) {
        const clean = String(id).replace(/^wix:image:\/\/v1\//,'').split('/')[0];
        return 'https://static.wixstatic.com/media/' + clean;
      }
      return null;
    }

    (async () => {
      const list = document.getElementById('posts');
      try {
        const wix = createClient({ modules: { posts }, auth: OAuthStrategy({ clientId }) });
        const res = await wix.posts.queryPosts().limit(50).find();
        const items = res.items || [];
        if (!items.length){ list.innerHTML = '<p class="prose">No posts yet — check back soon.</p>'; return; }
        list.innerHTML = items.map((p, i) => {
          const url = p.url && p.url.base ? (p.url.base + (p.url.path || '')) : '#';
          const date = p.firstPublishedDate ? new Date(p.firstPublishedDate).toLocaleDateString('en-CA',{year:'numeric',month:'long',day:'numeric'}) : '';
          const excerpt = p.excerpt || '';
          const cov = coverUrl(p);
          const bg = cov ? `background-image:url('${cov}')` : `background-image:${gradients[i % gradients.length]}`;
          const flip = i % 2 === 1;
          const cls = 'feature' + (flip ? ' right flip' : ' left');
          return `<a class="${cls}" href="${url}">
            <div class="img" style="${bg}"></div>
            <div class="body"><div class="date">${date}</div><h3>${p.title}</h3><p>${excerpt}</p><span class="more">Read the story →</span></div>
          </a>`;
        }).join('');
      } catch (e) {
        console.warn('Blog load failed:', e);
        list.innerHTML = '<p class="prose">Couldn’t load posts right now — please try again shortly.</p>';
      }
    })();
  </script>
</Base>
