---
import Base from '../layouts/Base.astro';
---
<Base title="Contact | Chris Stirling" description="Get in touch with author Chris Stirling.">
  <main class="wrap">
    <div class="pagehead">
      <div class="eyebrow">Contact</div>
      <h1>Get in touch</h1>
    </div>

    <section class="pad" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:18px;">
      <div class="card">
        <h3>Email</h3>
        <p class="prose" style="font-size:15px;">For readers, media, and everything in between:</p>
        <a class="btn btn-crimson btn-sm" href="mailto:chris@chrisstirling.com" style="margin-top:10px;">chris@chrisstirling.com</a>
      </div>
      <div class="card">
        <h3>Follow along</h3>
        <p class="prose" style="font-size:15px;">Behind-the-scenes pirate history and writing updates:</p>
        <p style="margin-top:10px;">
          <a href="https://www.youtube.com/@Chris.Stirling" style="color:var(--brass);">YouTube</a> ·
          <a href="https://www.tiktok.com/@chris_stirling" style="color:var(--brass);">TikTok</a> ·
          <a href="https://www.instagram.com/chrisstirling.writer/" style="color:var(--brass);">Instagram</a>
        </p>
      </div>
      <div class="card">
        <h3>Get the first chapter</h3>
        <p class="prose" style="font-size:15px;">Prefer to start reading? Grab Chapter One free.</p>
        <a class="btn btn-ghost btn-sm" href="/#books" style="margin-top:10px;">Start reading</a>
      </div>
    </section>
  </main>
</Base>
