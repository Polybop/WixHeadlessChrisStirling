---
import Base from '../layouts/Base.astro';
import { getLatestVideo } from '../lib/youtube.mjs';
import { getPosts, coverUrl } from '../lib/wix.mjs';
const cover = "https://static.wixstatic.com/media/5609ea_65bb8f67ff414550b698bf2dcfbd0324~mv2.png/v1/fill/w_440,h_700,al_c,q_90,enc_auto/Promo1%20Book%20Cover.png";
const coverThumb = "https://static.wixstatic.com/media/5609ea_65bb8f67ff414550b698bf2dcfbd0324~mv2.png/v1/fill/w_120,h_192,al_c,q_85,enc_auto/Promo1%20Book%20Cover.png";
const bermudaThumb = "/bermuda-cover.svg";
const headshot = "https://static.wixstatic.com/media/5609ea_eef3f98dbd2348fe86fcc3c394cbfff0~mv2.png/v1/fill/w_240,h_320,al_c,q_85,enc_auto/file.png";
const video = await getLatestVideo();
const recentPosts = (await getPosts()).slice(0, 3);

const personLd = { "@context": "https://schema.org", "@type": "Person", "name": "Chris Stirling", "url": "https://www.chrisstirling.com", "jobTitle": "Author", "sameAs": ["https://www.youtube.com/@Chris.Stirling", "https://www.tiktok.com/@chris_stirling", "https://www.instagram.com/chrisstirling.writer/"] };
const siteLd = { "@context": "https://schema.org", "@type": "WebSite", "name": "Chris Stirling", "url": "https://www.chrisstirling.com" };
const bookLd = { "@context": "https://schema.org", "@type": "Book", "name": "Crimson Cross: Azure Waves", "author": { "@type": "Person", "name": "Chris Stirling" }, "bookFormat": "https://schema.org/Hardcover", "url": "https://www.chrisstirling.com/books/azure-waves", "image": cover, "offers": [ { "@type": "Offer", "price": "49.99", "priceCurrency": "USD", "availability": "https://schema.org/PreOrder" }, { "@type": "Offer", "price": "19.99", "priceCurrency": "USD", "availability": "https://schema.org/PreOrder" } ] };
---
<Base title="Chris Stirling | Golden Age of Piracy Historical Fiction" description="Historical fiction by Chris Stirling. Step into the Golden Age of Piracy with Crimson Cross: Azure Waves — a Caribbean adventure of vengeance, brotherhood, and buried secrets. Preorder now.">
  <style is:global>
    .hero{display:grid;grid-template-columns:1.15fr .85fr;gap:54px;align-items:center;padding:54px 0 64px}
    .hero h1{font-size:54px;margin-bottom:16px}
    .hero h1 .sub{display:block;color:var(--teal);font-size:30px;font-style:italic;margin-top:8px}
    .lede{font-size:18px;color:#3A4A53;max-width:30em;margin-bottom:26px}
    .capture{background:var(--surface);border:1px solid var(--line);border-radius:12px;padding:20px;max-width:430px;box-shadow:0 12px 30px rgba(20,40,55,.08)}
    .capture .k{font-family:var(--serif);font-size:18px;margin-bottom:4px}
    .capture .s{font-size:13.5px;color:var(--muted);margin-bottom:14px}
    .field{display:flex;gap:8px}
    .field input{flex:1;background:#fff;border:1px solid var(--line);border-radius:7px;color:var(--ink);padding:0 13px;height:46px;font-size:14px;font-family:var(--sans)}
    .field input::placeholder{color:#9AA7B0}
    .field .btn-crimson{height:46px;padding:0 18px;white-space:nowrap}
    .formmsg{font-size:13px;color:var(--teal-d);margin-top:10px;min-height:18px}
    .orrow{display:flex;align-items:center;gap:14px;margin-top:22px;max-width:430px}
    .orrow .ln{flex:1;height:1px;background:var(--line)}
    .orrow span{color:var(--muted);font-size:12px;letter-spacing:.1em}
    .preorder{display:flex;gap:12px;margin-top:18px;flex-wrap:wrap}
    .cover{position:relative;justify-self:center}
    .cover img{width:340px;max-width:100%;border-radius:6px;box-shadow:0 26px 60px rgba(20,40,55,.28);display:block}
    .cover .tag{position:absolute;top:-14px;right:-14px;background:var(--crimson);color:#fff;font-size:12px;font-weight:600;letter-spacing:.08em;padding:7px 12px;border-radius:6px;text-transform:uppercase}
    .strip{border-top:1px solid var(--line);border-bottom:1px solid var(--line);background:var(--surface)}
    .strip .wrap{display:flex;gap:40px;justify-content:center;flex-wrap:wrap;padding:16px 28px;font-size:13.5px;color:var(--muted)}
    .strip b{color:var(--teal-d);font-weight:600}
    .sec-label{color:var(--crimson);font-size:12px;font-weight:600;letter-spacing:.2em;text-transform:uppercase;margin-bottom:12px}
    .books{display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:20px}
    .book{background:var(--surface);border:1px solid var(--line);border-radius:12px;padding:16px;display:flex;gap:16px;align-items:center;box-shadow:0 8px 22px rgba(20,40,55,.06);text-decoration:none;color:inherit;transition:transform .15s ease,box-shadow .15s ease,border-color .15s ease}
    .book:hover{transform:translateY(-3px);box-shadow:0 16px 34px rgba(20,40,55,.13);border-color:rgba(20,128,142,.4)}
    .book .bthumb{width:66px;height:106px;object-fit:cover;border-radius:5px;box-shadow:0 6px 16px rgba(20,40,55,.22);flex:none;background:var(--surface2)}
    .book .binfo{display:flex;flex-direction:column;min-width:0}
    .book .bt{font-family:var(--serif);font-size:18px;line-height:1.2;margin-bottom:4px}
    .book .bfmt{display:block;font-family:var(--sans);font-size:12px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:var(--muted);margin-top:3px}
    .book .bp{color:var(--brass);font-weight:600;margin:8px 0 8px}
    .book .bgo{color:var(--teal-d);font-weight:600;font-size:14px}
    .ytfacade{position:relative;aspect-ratio:16/9;max-width:840px;border-radius:14px;overflow:hidden;background-size:cover;background-position:center;cursor:pointer;box-shadow:0 16px 40px rgba(20,40,55,.18)}
    .ytfacade::after{content:'';position:absolute;inset:0;background:rgba(16,36,46,.28)}
    .ytplay{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);z-index:2;width:74px;height:74px;border-radius:50%;border:0;background:var(--crimson);color:#fff;font-size:26px;cursor:pointer}
    .about{display:grid;grid-template-columns:200px 1fr;gap:40px;align-items:center}
    .about img{width:200px;border-radius:10px;display:block}
    .posts{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:18px}
    .post{position:relative;overflow:hidden;isolation:isolate;background:var(--surface);border:1px solid var(--line);border-radius:12px;padding:20px;box-shadow:0 8px 22px rgba(20,40,55,.06);text-decoration:none;color:inherit;display:flex;flex-direction:column;justify-content:flex-end;min-height:230px;transition:transform .15s ease,box-shadow .15s ease,border-color .15s ease}
    .post:hover{transform:translateY(-3px);box-shadow:0 16px 34px rgba(20,40,55,.13);border-color:rgba(20,128,142,.4)}
    .post:hover[data-cover='1']::before{opacity:.78}
    .post[data-cover='1']::before{content:'';position:absolute;inset:0;z-index:-2;background-image:var(--cv);background-size:cover;background-position:center 28%;opacity:.62;transition:opacity .15s ease}
    .post[data-cover='1']::after{content:'';position:absolute;inset:0;z-index:-1;background:linear-gradient(180deg,rgba(255,255,255,0) 0%,rgba(255,255,255,.32) 30%,rgba(255,255,255,.80) 52%,rgba(255,255,255,.97) 70%,rgba(255,255,255,1) 100%)}
    .post .pt{font-family:var(--serif);font-size:18px;font-weight:700;line-height:1.25;margin-bottom:7px;text-shadow:0 1px 0 rgba(255,255,255,.9)}
    .post .pe{color:#3A4750;font-size:14px;line-height:1.5;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
    .post .pgo{color:var(--teal-d);font-weight:600;font-size:14px;padding-top:11px}
    @media(max-width:880px){
      .hero{grid-template-columns:1fr;gap:34px;padding:36px 0 46px}
      .hero h1{font-size:40px} .hero h1 .sub{font-size:24px}
      .cover{order:-1} .cover img{width:240px}
      .about{grid-template-columns:1fr} .about img{width:150px}
    }
  </style>

  <header class="wrap">
    <div class="hero">
      <div>
        <div class="eyebrow">Golden Age of Piracy · Historical Fiction</div>
        <h1>Crimson Cross<span class="sub">Azure Waves</span></h1>
        <p class="lede">Charleston burns, a family falls, and sixteen-year-old Samuel Drayton is cast into the lawless waters of the Caribbean — where the line between pirate and patriot is thinner than he ever imagined.</p>
        <div class="capture">
          <div class="k">Start reading free</div>
          <div class="s">Get the first chapter as a PDF, plus the occasional letter from the writing desk.</div>
          <form class="field" id="signup">
            <input type="email" id="email" placeholder="you@email.com" required />
            <button class="btn btn-crimson" type="submit">Send me Chapter One</button>
          </form>
          <div class="formmsg" id="formmsg"></div>
        </div>
        <div class="orrow"><span class="ln"></span><span>OR PREORDER NOW</span><span class="ln"></span></div>
        <div class="preorder">
          <a class="btn btn-crimson" href="/books/azure-waves">Preorder hardcover · $49.99</a>
          <a class="btn btn-ghost" href="/books/azure-waves">Paperback · $19.99</a>
        </div>
      </div>
      <div class="cover">
        <span class="tag">Coming mid-2026</span>
        <img src={cover} alt="Crimson Cross: Azure Waves cover" />
      </div>
    </div>
  </header>

  <div class="strip">
    <div class="wrap">
      <div><b>Book one</b> of the Crimson Cross series</div>
      <div><b>Setting:</b> the Caribbean, 1700–1718</div>
      <div><b>For readers of</b> authentic maritime adventure</div>
    </div>
  </div>

  <section class="pad wrap" id="books" style="padding-top:50px;">
    <div class="sec-label">The books</div>
    <h2>The Crimson Cross series</h2>
    <div class="books">
      <a class="book" href="/books/azure-waves">
        <img class="bthumb" src={coverThumb} alt="Crimson Cross: Azure Waves cover" loading="lazy" />
        <div class="binfo"><div class="bt">Azure Waves <span class="bfmt">Hardcover</span></div><div class="bp">$49.99</div><span class="bgo">View →</span></div>
      </a>
      <a class="book" href="/books/azure-waves">
        <img class="bthumb" src={coverThumb} alt="Crimson Cross: Azure Waves cover" loading="lazy" />
        <div class="binfo"><div class="bt">Azure Waves <span class="bfmt">Paperback</span></div><div class="bp">$19.99</div><span class="bgo">View →</span></div>
      </a>
      <a class="book" href="/books/bermuda-years">
        <img class="bthumb" src={bermudaThumb} alt="Crimson Cross: The Bermuda Years cover" loading="lazy" />
        <div class="binfo"><div class="bt">The Bermuda Years <span class="bfmt">Prequel</span></div><div class="bp">$14.99</div><span class="bgo">More info →</span></div>
      </a>
    </div>
  </section>

  {video && (
    <section class="pad wrap" style="padding-top:40px;">
      <div class="sec-label">Watch</div>
      <h2>From the channel</h2>
      <div class="ytfacade" id="ytfacade" data-id={video.id} style={`background-image:url('${video.thumb}')`}>
        <button class="ytplay" aria-label="Play latest video">▶</button>
      </div>
      <p class="prose" style="margin-top:12px;"><a href="https://www.youtube.com/@Chris.Stirling" style="color:var(--teal-d);">More pirate history on YouTube →</a></p>
    </section>
  )}

  <section class="pad" style="background:var(--surface2);margin-top:24px;">
    <div class="wrap about">
      <img src={headshot} alt="Chris Stirling" />
      <div>
        <div class="sec-label">The author</div>
        <h2>From the frozen prairies to warm waters</h2>
        <p class="prose">Chris Stirling traded Winnipeg's winters for the reefs of Bermuda, where he found his passion for maritime history. A technology manager by day and adventure storyteller by night, he brings systematic research and a love of human drama to the Crimson Cross series — written between chasing a toddler and following his beloved Winnipeg Jets.</p>
        <a class="btn btn-ghost btn-sm" href="/about" style="margin-top:6px;">More about Chris</a>
      </div>
    </div>
  </section>

  <section class="pad wrap" id="blog" style="padding-top:40px;">
    <div class="sec-label">From the blog</div>
    <h2>Pirate history &amp; the writing journey</h2>
    <div class="posts">
      {recentPosts.length ? recentPosts.map((p) => {
        const img = coverUrl(p);
        const url = '/blog/' + (p.slug || (p.url && p.url.relativeUrl ? p.url.relativeUrl.replace(/^\/+/, '') : ''));
        return (
          <a class="post" href={url} data-cover={img ? '1' : '0'} style={img ? `--cv:url('${img}')` : ''}>
            <div class="pt">{p.title}</div>
            <div class="pe">{p.excerpt || ''}</div>
            <span class="pgo">Read →</span>
          </a>
        );
      }) : (
        <div class="post"><div class="pt">Visit the blog</div><div class="pe">Stories from the Golden Age of Piracy and behind-the-scenes notes.</div><a href="/blog" class="pgo">Read the latest →</a></div>
      )}
    </div>
    {recentPosts.length > 0 && (
      <p class="prose" style="margin-top:16px;"><a href="/blog" style="color:var(--teal-d);">See all posts →</a></p>
    )}
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(personLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(siteLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(bookLd)} />

  <script>
    const fac = document.getElementById('ytfacade');
    fac && fac.addEventListener('click', () => {
      const id = fac.dataset.id;
      fac.innerHTML = '<iframe style="position:absolute;inset:0;width:100%;height:100%;border:0;" src="https://www.youtube-nocookie.com/embed/' + id + '?autoplay=1" title="Latest video" allow="autoplay; encrypted-media; picture-in-picture" allowfullscreen></iframe>';
    });

    const form = document.getElementById('signup');
    form?.addEventListener('submit', async (ev) => {
      ev.preventDefault();
      const email = document.getElementById('email').value;
      const msg = document.getElementById('formmsg');
      msg.textContent = 'Sending…';
      try {
        const r = await fetch('/api/subscribe', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ email }) });
        msg.textContent = r.ok ? 'Check your inbox for Chapter One!' : 'Thanks — we’ll be in touch.';
      } catch { msg.textContent = 'Thanks — we’ll be in touch.'; }
    });
  </script>
</Base>
